  score              Float             @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([workspaceId, score])
  @@index([contentId])
  @@map("content_performance")
}

model DailyReport {
  id                 String            @id @default(cuid())
  workspaceId        String?
  brandId            String?
  reportDate         DateTime
  metricsSummary     Json
  insights           Json
  generatedBy        String            @default("system")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([workspaceId, brandId, reportDate])
  @@index([reportDate])
  @@map("daily_reports")
}

model TrendingTopic {
  id                 String            @id @default(cuid())
  workspaceId        String?
  brandId            String?
  topic              String
  score              Float             @default(0)
  sourcePlatforms    String[]
  evidence           Json?
  firstSeenAt        DateTime          @default(now())
  lastSeenAt         DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([workspaceId, score])
  @@index([topic])
  @@map("trending_topics")
}

model OptimizationRule {
  id                 String                  @id @default(cuid())
  workspaceId        String?
  brandId            String?
  ruleKey            String
  targetModule       OptimizationTargetModule
  ruleType           OptimizationRuleType
  description        String
  score              Float                   @default(0)
  confidence         Float                   @default(0)
  active             Boolean                 @default(true)
  payload            Json?
  createdFromReportId String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([workspaceId, ruleKey])
  @@index([workspaceId, targetModule, active])
  @@map("optimization_rules")
}

model OptimizationLog {
  id                 String            @id @default(cuid())
  workspaceId        String?
  brandId            String?
  ruleId             String?
  sourceModule       String
  action             String
  decision           Json?
  createdAt          DateTime          @default(now())

  @@index([workspaceId, createdAt])
  @@map("optimization_logs")
}

model AbTest {
  id                 String            @id @default(cuid())
  workspaceId        String?
  brandId            String?
  contentId          String?
  videoId            String?
  testType           String
  hypothesis         String
  status             AbTestStatus      @default(DRAFT)
  metricName         String
  startedAt          DateTime          @default(now())
  endedAt            DateTime?
  winnerVariantKey   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  results            AbTestResult[]

  @@index([workspaceId, status])
  @@map("ab_tests")
}

model AbTestResult {
  id                 String            @id @default(cuid())
  abTestId           String
  variantKey         String
  variantLabel       String?
  impressions        Int               @default(0)
  views              Int               @default(0)
  clicks             Int               @default(0)
  likes              Int               @default(0)
  comments           Int               @default(0)
  shares             Int               @default(0)
  saves              Int               @default(0)
  completionRate     Float             @default(0)
  score              Float             @default(0)
  isWinner           Boolean           @default(false)
  raw                Json?
  recordedAt         DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  test               AbTest            @relation(fields: [abTestId], references: [id], onDelete: Cascade)

  @@index([abTestId, score])
  @@map("ab_test_results")
}
