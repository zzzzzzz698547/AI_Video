generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStyle {
  AUTO
  HOT_SALE
  PREMIUM
  HUMOR
  EDUCATIONAL
}

enum ContentVariantType {
  TITLE
  POST_COPY
  SCRIPT
}

enum VideoStyle {
  AUTO
  SALES
  PREMIUM
  TECH
  SOCIAL
}

enum VideoStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
}

enum VideoMediaMode {
  REAL_MEDIA
  AI_IMAGE
  HYBRID
}

enum AiProviderType {
  OPENAI
  GEMINI
}

enum UrlAnalysisStatus {
  PROCESSING
  READY
  FAILED
}

enum UrlAnalysisSourceType {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  FACEBOOK
  THREADS
  VIMEO
  GENERIC
}

enum UrlAnalysisVariantType {
  TITLE
  HIGHLIGHT
  SCRIPT
  CUT_PLAN
}

enum VideoSegmentType {
  HOOK
  BODY
  CTA
}

enum MediaAssetType {
  IMAGE
  VIDEO
  AUDIO
  LOGO
  SUBTITLE
  THUMBNAIL
}

enum MediaSourceType {
  MOCK
  FREE_LIBRARY
  GENERATIVE
}

enum PublishingPlatform {
  FACEBOOK
  INSTAGRAM
  THREADS
  YOUTUBE
}

enum SocialPlatform {
  FACEBOOK_PAGE
  INSTAGRAM
  THREADS
}

enum SocialAdapterStatus {
  ACTIVE
  EXPIRED
  ERROR
}

enum SocialPublishJobStatus {
  DRAFT
  QUEUED
  PUBLISHING
  SUCCESS
  FAILED
}

enum TenantStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum LicensePlan {
  BASIC
  PRO
  ENTERPRISE
}

enum TenantUserRole {
  OWNER
  ADMIN
  MEMBER
}

enum LicenseKeyStatus {
  UNUSED
  ACTIVE
  EXPIRED
  REVOKED
}

enum PublishingStatus {
  DRAFT
  QUEUED
  SCHEDULED
  PROCESSING
  SUCCESS
  FAILED
  RETRYING
  PARTIAL_SUCCESS
}

enum PublishSourceType {
  VIDEO_OUTPUT
  CONTENT_VARIANT
}

enum OptimizationTargetModule {
  CONTENT
  VIDEO
  CRM
}

enum OptimizationRuleType {
  TITLE
  HOOK
  CTA
  SCHEDULE
  LENGTH
  STYLE
  KEYWORD
  PLATFORM
}

enum AbTestStatus {
  DRAFT
  RUNNING
  COMPLETED
  PAUSED
  FAILED
}

enum QueueState {
  PENDING
  ENQUEUED
  PROCESSING
  DONE
  FAILED
}

enum WorkspaceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BrandStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProductStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  GENERATED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum VideoRecordStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum SalesStage {
  NEW_INQUIRY
  INFO_REQUESTED
  CONSIDERING
  PRICE_DISCUSSED
  HIGH_INTENT
  PAYMENT_PENDING
  WON
  LOST
  AFTER_SALES
}

enum RecommendedNextAction {
  ASK_CLARIFYING_QUESTION
  SEND_PRICE_LIST
  SEND_RECOMMENDATION_LIST
  INVITE_TO_FORM
  INVITE_TO_LINE
  TRANSFER_TO_HUMAN
  SEND_OFFER
  AFTER_SALES_FOLLOW_UP
}

enum CustomerTemperature {
  COLD
  WARM
  HOT
}

enum IntentLabel {
  ASK_PRICE
  ASK_SPEC
  ASK_STOCK
  ASK_INSTALLATION
  ASK_PAYMENT
  COMPARE_PRODUCTS
  HIGH_BUY_INTENT
  JUST_BROWSING
  AFTER_SALES
  COMPLAINT
  UNKNOWN
}

enum MessageSender {
  CUSTOMER
  AI
  HUMAN
  SYSTEM
}

enum HandoffStatus {
  NONE
  REQUESTED
  PENDING
  ASSIGNED
  RESOLVED
}

enum HandoffReason {
  HIGH_VALUE
  COMPLAINT
  UNCERTAIN_ANSWER
  REQUESTED_BY_CUSTOMER
  COMPLIANCE
  MANUAL
}

enum KnowledgeArticleType {
  FAQ
  PRODUCT
  POLICY
  BRAND_TONE
  PROHIBITED
}

enum FollowUpRuleTrigger {
  NO_REPLY
  HOT_LEAD
  FORM_SUBMITTED
  PURCHASE_COMPLETED
  AFTER_PURCHASE
}

enum ChannelAdapterType {
  WEBSITE_CHAT
  FACEBOOK_MESSENGER
  INSTAGRAM_DM
  LINE_OFFICIAL_ACCOUNT
  COMMENT_TO_LEAD
}

enum ChannelAdapterStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum MetaDataDeletionStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  NOT_FOUND
  FAILED
}

enum CommentLeadStatus {
  NEW
  REPLIED
  DM_SENT
  FORM_SENT
  CONVERTED
  IGNORED
}

enum EscalationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DealStatus {
  NEW
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

enum LeadSourcePlatform {
  IG
  FB
  THREADS
  YOUTUBE
  DIRECT
  UNKNOWN
}

enum FollowUpChannel {
  LINE
  EMAIL
  WEBHOOK
}

enum LandingPageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  ANALYST
  SUPPORT
}

model ContentRequest {
  id               String           @id @default(cuid())
  tenantId         String?
  productName      String
  productDescription String
  targetAudience   String
  priceRange       String?
  usageScenario    String?
  keywords         String[]
  requestedStyle   ContentStyle     @default(AUTO)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  generatedContent GeneratedContent?

  @@index([tenantId, createdAt])
  @@map("content_requests")
}

model GeneratedContent {
  id             String            @id @default(cuid())
  tenantId       String?
  requestId      String            @unique
  resolvedStyle  ContentStyle
  summary        String
  titleCount     Int
  postCount      Int
  scriptCount    Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  request        ContentRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  variants       ContentVariant[]
  videoProjects   VideoProject[]

  @@index([tenantId, createdAt])
  @@map("generated_contents")
}

model ContentVariant {
  id                   String             @id @default(cuid())
  generatedContentId   String
  variantType          ContentVariantType
  variantIndex         Int
  title                String?
  previewText          String
  payload              Json
  hashtags             String[]
  platforms            String[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  generatedContent     GeneratedContent    @relation(fields: [generatedContentId], references: [id], onDelete: Cascade)
  publishingJobs       PublishingJob[]

  @@map("content_variants")
}

model VideoProject {
  id                  String         @id @default(cuid())
  tenantId            String?
  contentId           String
  title               String
  scriptSnapshot      Json
  resolvedStyle       VideoStyle
  mediaMode           VideoMediaMode @default(HYBRID)
  targetDurationSeconds Int
  aspectRatio         String         @default("9:16")
  resolution          String         @default("1080x1920")
  status              VideoStatus    @default(DRAFT)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tenant              Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  content             GeneratedContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  segments            VideoSegment[]
  assets              VideoAsset[]
  output              VideoOutput?
  socialPublishJobs   SocialPublishJob[]

  @@index([tenantId, createdAt])
  @@map("video_projects")
}

model AiProviderBinding {
  id                 String          @id @default(cuid())
  scopeKey           String          @default("GLOBAL")
  provider           AiProviderType
  label              String?
  apiKeyEncrypted    String
  apiKeyLast4        String
  apiBaseUrl         String?
  defaultModel       String?
  isActive           Boolean         @default(true)
  lastVerifiedAt     DateTime?
  lastError          String?
  metadata           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([scopeKey, provider])
  @@map("ai_provider_bindings")
}

model VideoSegment {
  id                String          @id @default(cuid())
  videoProjectId    String
  segmentType       VideoSegmentType
  segmentIndex      Int
  startSecond       Int
  endSecond         Int
  text              Json
  voiceText         String
  subtitleText      String
  visualPrompt      String
  transition        String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  videoProject      VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  @@map("video_segments")
}

model VideoAsset {
  id                String          @id @default(cuid())
  videoProjectId    String
  segmentId         String?
  assetType         MediaAssetType
  sourceType        MediaSourceType
  title             String
  sourceUrl         String?
  localPath         String?
  prompt            String
  durationSeconds   Int
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  videoProject      VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  @@map("video_assets")
}

model VideoOutput {
  id                String          @id @default(cuid())
  tenantId          String?
  videoProjectId    String          @unique
  filePath          String
  publicUrl         String?
  fileSizeBytes     BigInt?
  width             Int
  height            Int
  durationSeconds   Int
  outputFormat      String          @default("mp4")
  status            VideoStatus     @default(READY)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  videoProject      VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  publishingJobs    PublishingJob[]

  @@index([tenantId, createdAt])
  @@map("video_outputs")
}

model PlatformAccount {
  id                  String            @id @default(cuid())
  tenantId            String?
  workspaceId         String?
  brandId             String?
  platform            PublishingPlatform
  accountName         String
  displayName         String?
  externalAccountId    String?
  isActive            Boolean           @default(true)
  metadata            Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenant              Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  workspace           Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  brand               Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  token               PlatformToken?

  @@index([tenantId, platform, createdAt])
  @@map("platform_accounts")
}

model PlatformToken {
  id                      String            @id @default(cuid())
  platformAccountId       String            @unique
  accessTokenEncrypted    String
  refreshTokenEncrypted   String?
  tokenType               String            @default("oauth2")
  expiresAt               DateTime?
  scopes                  String[]
  metadata                Json?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  account                 PlatformAccount   @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)

  @@map("platform_tokens")
}

model SocialAdapter {
  id                    String              @id @default(cuid())
  tenantId              String
  platform              SocialPlatform
  accountName           String
  displayName           String?
  externalAccountId     String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  scopes                String[]
  status                SocialAdapterStatus @default(ACTIVE)
  tokenExpiresAt        DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs                  SocialPublishJob[]

  @@unique([tenantId, platform, externalAccountId])
  @@index([tenantId, platform, status])
  @@map("social_adapters")
}

model SocialPublishJob {
  id             String                 @id @default(cuid())
  tenantId       String
  videoId        String
  platform       SocialPlatform
  adapterId      String
  caption        String
  mediaUrl       String
  scheduledAt    DateTime?
  status         SocialPublishJobStatus @default(DRAFT)
  externalPostId String?
  permalink      String?
  errorMessage   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  video          VideoProject           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  adapter        SocialAdapter          @relation(fields: [adapterId], references: [id], onDelete: Cascade)

  @@index([tenantId, videoId, createdAt])
  @@index([adapterId, status, scheduledAt])
  @@map("social_publish_jobs")
}

model MetaDataDeletionRequest {
  id                 String               @id @default(cuid())
  metaUserId         String
  confirmationCode   String               @unique
  status             MetaDataDeletionStatus @default(RECEIVED)
  callbackUrl        String
  statusUrl          String
  signedRequest      Json?
  requestPayload     Json?
  responsePayload    Json?
  deletedPlatformAccounts Int              @default(0)
  deletedPlatformTokens   Int              @default(0)
  deletedChannelAdapters  Int              @default(0)
  errorMessage       String?
  metadata           Json?
  completedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([metaUserId, createdAt])
  @@map("meta_data_deletion_requests")
}

model PublishingJob {
  id                 String              @id @default(cuid())
  tenantId           String?
  workspaceId        String?
  brandId            String?
  sourceType         PublishSourceType
  contentVariantId   String?
  videoOutputId      String?
  caption            String
  hashtags           String[]
  platforms          PublishingPlatform[]
  publishAt          DateTime?
  status             PublishingStatus    @default(DRAFT)
  attempts           Int                 @default(0)
  maxAttempts        Int                 @default(5)
  errorMessage       String?
  retryAt            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  logs               PublishLog[]
  queueItem          PublishQueue?
  workspace          Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  brand             Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  contentVariant     ContentVariant?     @relation(fields: [contentVariantId], references: [id], onDelete: SetNull)
  videoOutput        VideoOutput?        @relation(fields: [videoOutputId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("publishing_jobs")
}

model PublishLog {
  id                 String            @id @default(cuid())
  tenantId           String?
  publishingJobId    String
  platform           PublishingPlatform
  action             String
  status             PublishingStatus
  requestPayload     Json?
  responsePayload    Json?
  errorMessage       String?
  createdAt          DateTime          @default(now())
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  publishingJob      PublishingJob     @relation(fields: [publishingJobId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("publish_logs")
}

model PublishQueue {
  id                 String          @id @default(cuid())
  tenantId           String?
  publishingJobId    String          @unique
  queueName          String
  bullJobId          String?
  queueState         QueueState      @default(PENDING)
  scheduledFor       DateTime?
  lastAttemptAt      DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  publishingJob      PublishingJob   @relation(fields: [publishingJobId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("publish_queue")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String
  avatarUrl         String?
  status            String           @default("ACTIVE")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenantMemberships TenantUser[]
  memberships       WorkspaceMember[]
  ownedWorkspaces   Workspace[]      @relation("WorkspaceOwner")

  @@map("users")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  status             TenantStatus        @default(ACTIVE)
  plan               LicensePlan         @default(BASIC)
  licenseExpiresAt   DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  licenseKeys        LicenseKey[]
  users              TenantUser[]
  workspaces         Workspace[]
  contentRequests    ContentRequest[]
  generatedContents  GeneratedContent[]
  videoProjects      VideoProject[]
  videoOutputs       VideoOutput[]
  platformAccounts   PlatformAccount[]
  socialAdapters     SocialAdapter[]
  socialPublishJobs  SocialPublishJob[]
  publishingJobs     PublishingJob[]
  publishLogs        PublishLog[]
  publishQueues      PublishQueue[]
  urlAnalysisRequests VideoUrlAnalysisRequest[]

  @@index([status, licenseExpiresAt])
  @@map("tenants")
}

model TenantUser {
  id         String         @id @default(cuid())
  tenantId   String
  userId     String
  role       TenantUserRole @default(MEMBER)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, role])
  @@map("tenant_users")
}

model LicenseKey {
  id                String           @id @default(cuid())
  code              String           @unique
  plan              LicensePlan
  maxUsers          Int
  maxVideos         Int
  maxSocialAccounts Int
  expiresAt         DateTime
  status            LicenseKeyStatus @default(UNUSED)
  activatedAt       DateTime?
  tenantId          String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@map("license_keys")
}

model Workspace {
  id                String           @id @default(cuid())
  tenantId          String?
  ownerId           String
  name              String
  slug              String           @unique
  status            WorkspaceStatus   @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  owner             User             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members           WorkspaceMember[]
  brands            Brand[]
  products          Product[]
  contents          Content[]
  videos            Video[]
  videoUrlAnalysisRequests VideoUrlAnalysisRequest[]
  platformAccounts  PlatformAccount[]
  publishingJobs    PublishingJob[]
  trackingLinks     TrackingLink[]
  landingPages      LandingPage[]
  deals             Deal[]
  customerProfiles  CustomerProfile[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  conversationMessages ConversationMessage[]
  leadScores        LeadScore[]
  intentPredictions IntentPrediction[]
  aiReplyLogs       AiReplyLog[]
  knowledgeBaseArticles KnowledgeBaseArticle[]
  faqItems          FaqItem[]
  handoffLogs       HandoffLog[]
  followUpRules     FollowUpRule[]
  followUpJobs      FollowUpJob[]
  commentLeads      CommentLead[]
  channelAdapters   ChannelAdapter[]
  escalationRules   EscalationRule[]
  messageTemplates  MessageTemplate[]
  followUpLogs      FollowUpLog[]
  metrics           Metric[]
  leads             Lead[]

  @@index([tenantId, createdAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id                String           @id @default(cuid())
  workspaceId       String
  userId            String
  role              MemberRole       @default(EDITOR)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Brand {
  id                String           @id @default(cuid())
  workspaceId       String
  name              String
  slug              String
  status            BrandStatus      @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  products          Product[]
  contents          Content[]
  videos            Video[]
  videoUrlAnalysisRequests VideoUrlAnalysisRequest[]
  platformAccounts  PlatformAccount[]
  publishingJobs    PublishingJob[]
  trackingLinks     TrackingLink[]
  landingPages      LandingPage[]
  deals             Deal[]
  customerProfiles  CustomerProfile[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  conversationMessages ConversationMessage[]
  leadScores        LeadScore[]
  intentPredictions IntentPrediction[]
  aiReplyLogs       AiReplyLog[]
  knowledgeBaseArticles KnowledgeBaseArticle[]
  faqItems          FaqItem[]
  handoffLogs       HandoffLog[]
  followUpRules     FollowUpRule[]
  followUpJobs      FollowUpJob[]
  commentLeads      CommentLead[]
  channelAdapters   ChannelAdapter[]
  escalationRules   EscalationRule[]
  messageTemplates  MessageTemplate[]
  followUpLogs      FollowUpLog[]
  metrics           Metric[]
  leads             Lead[]

  @@unique([workspaceId, slug])
  @@map("brands")
}

model Product {
  id                String           @id @default(cuid())
  workspaceId       String
  brandId           String
  name              String
  slug              String
  description       String?
  status            ProductStatus    @default(ACTIVE)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand             Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contents          Content[]
  trackingLinks     TrackingLink[]
  landingPages      LandingPage[]
  leads             Lead[]
  deals             Deal[]

  @@unique([workspaceId, slug])
  @@map("products")
}

model Content {
  id                String           @id @default(cuid())
  workspaceId       String
  brandId           String
  productId         String?
  title             String
  contentType       String
  payload           Json
  status            ContentStatus     @default(DRAFT)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand             Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product           Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  videos            Video[]
  trackingLinks     TrackingLink[]

  @@map("contents")
}

model Video {
  id                String           @id @default(cuid())
  workspaceId       String
  brandId           String
  contentId         String?
  title             String
  filePath          String?
  playbackUrl       String?
  status            VideoRecordStatus @default(DRAFT)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand             Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content           Content?         @relation(fields: [contentId], references: [id], onDelete: SetNull)
  trackingLinks     TrackingLink[]

  @@map("videos")
}

model VideoUrlAnalysisRequest {
  id                  String                   @id @default(cuid())
  tenantId            String?
  workspaceId         String?
  brandId             String?
  sourceUrl           String
  sourceHost          String
  sourceType          UrlAnalysisSourceType    @default(GENERIC)
  sourceTitle         String?
  sourceDescription   String?
  analysisGoal        String
  analysisMode        String?
  targetAudience      String?
  desiredTone        String?
  desiredLengthSeconds Int                      @default(30)
  focusKeywords       String[]
  status              UrlAnalysisStatus        @default(PROCESSING)
  errorMessage        String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  tenant              Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
