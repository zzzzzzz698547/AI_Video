{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm run prisma:generate && npm run build:api",
    "watchPatterns": [
      "apps/api/**",
      "packages/**",
      "package.json",
      "package-lock.json",
      "tsconfig.base.json",
      ".env.example",
      "railway.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "npm --workspace @ai-vidio/api run db:push",
    "startCommand": "npm --workspace @ai-vidio/api run start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
